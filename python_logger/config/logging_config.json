{
  "version": 1,
  "disable_existing_loggers": false,

  "filters": {
    "non_error": {
      "()": "my_logger.NonErrorFilter"
    }
  },

  "formatters": {
    "simple": {
      "format": "[%(levelname)s|%(threadName)s|%(module)s:%(lineno)d] %(asctime)s | %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    },

    "json": {
      "()": "my_logger.MyJSONFormatter",

      "fmt_keys": {
        "level": "levelname",
        "message": "message",
        "timestamp": "timestamp",
        "logger": "name",
        "module": "module",
        "function": "funcName",
        "line": "lineno",
        "thread_name": "threadName"
      }
    }
  },

  "handlers": {
    "stdout": {
      "class": "logging.StreamHandler",
      "level": "DEBUG",
      "formatter": "simple",
      "stream": "ext://sys.stdout"
    },

    "file_json": {
      "class": "logging.handlers.RotatingFileHandler",
      "level": "WARNING",
      "formatter": "json",

      "filename": "logs/my_app.log.jsonl",

      "maxBytes": 1000000,
      "backupCount": 3,

      "encoding": "utf-8"
    }
  },

  "root": {
    "level": "DEBUG",

    "handlers": [
      "stdout",
      "file_json"
    ]
  }
}